# Career-Ops environment — local overrides.
# Copy to `.env` and fill in. NEVER commit `.env` (it's in .gitignore).

# Gemini API key for evaluation (scan.mjs scores via Gemini when available).
# Get a free key at https://aistudio.google.com/apikey
# Free tier: 15 RPM, 1M tokens/day — plenty for daily scans.
GEMINI_API_KEY=

# Optional: override the Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: scanner behavior
# SCAN_MAX_COMPANIES=5          # test mode — only scan first N companies
# SCAN_DRY_RUN=1                # don't write files, just log

# Gmail lead poller — fetch-gmail-leads.mjs scans your inbox for job alerts
# from curated senders (config/gmail-sources.yml), extracts ATS URLs, and
# stages them in data/inbox-leads.md.
#
# Generate a Gmail App Password: https://myaccount.google.com/apppasswords
# (requires 2FA enabled). Scope: "Mail". Do NOT reuse passwords from other tools.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Local Ollama-compatible LLM endpoint for rank-leads.mjs (job fit scoring).
# Set to your fleet proxy or local ollama host.
OLLAMA_URL=
# Optional: override model (default: Qwen/Qwen3.6-35B-A3B-FP8)
# RANK_MODEL=Qwen/Qwen3.6-35B-A3B-FP8
