# Career-Ops environment — local overrides.
# Copy to `.env` and fill in. NEVER commit `.env` (it's in .gitignore).

# Gemini API key for evaluation (scan.mjs scores via Gemini when available).
# Get a free key at https://aistudio.google.com/apikey
# Free tier: 15 RPM, 1M tokens/day — plenty for daily scans.
GEMINI_API_KEY=

# Optional: override the Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: scanner behavior
# SCAN_MAX_COMPANIES=5          # test mode — only scan first N companies
# SCAN_DRY_RUN=1                # don't write files, just log
